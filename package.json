{
  "name": "myfacturation360",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:backup": "node scripts/backup-db.cjs",
    "db:push": "node scripts/backup-db.cjs && node scripts/with-db-env.cjs db push",
    "db:migrate": "node scripts/backup-db.cjs && node scripts/with-db-env.cjs migrate dev",
    "db:migrate:deploy": "node scripts/with-db-env.cjs migrate deploy",
    "db:migrate:resolve": "node scripts/with-db-env.cjs migrate resolve",
    "db:studio": "node scripts/with-db-env.cjs studio",
    "db:seed": "node scripts/with-db-env.cjs db seed",
    "env:pull": "vercel env pull .env.local"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.0",
    "@prisma/client": "^5.22.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.460.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "nodemailer": "^7.0.0",
    "npx": "^10.2.2",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^3.8.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
