// Myfacturation — Multi-tenant SaaS facturation
// NextAuth + billing (userId sur toutes les entités)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ——— NextAuth (tables standards) ———
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires   DateTime
  @@id([identifier, token])
}

// ——— User (profil + abonnement futur) ———
model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?   // pour login email/password
  verificationCode     String?   // code à 6 chiffres
  verificationCodeExp  DateTime? // expiration du code
  planType             String    @default("free")   // free | premium
  subscriptionStatus   String?   // null | active | cancelled | past_due (pour Stripe plus tard)
  subscriptionStart   DateTime?
  subscriptionEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  accounts            Account[]
  sessions            Session[]
  clients              Client[]
  companies            Company[]
  quotes               Quote[]
  invoices             Invoice[]
  expenses             Expense[]
  activityLogs         ActivityLog[]
  billingSettings      BillingSettings?
  billingProducts      BillingProduct[]
}

// ——— Facturation (multi-tenant: userId partout) ———

model Client {
  id              String    @id @default(cuid())
  userId          String
  type            String    // "particulier" | "professionnel"
  firstName       String
  lastName        String
  email           String
  phone           String?
  address         String?
  postalCode      String?
  city            String?
  country         String?
  language        String?   @default("fr")
  notes           String?
  companyName     String?
  companyAddress  String?
  siret           String?
  vatNumber       String?
  legalForm       String?
  createdAt       DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes         Quote[]
  invoices       Invoice[]
  @@index([userId])
}

model Company {
  id          String    @id @default(cuid())
  userId      String
  name        String
  legalName   String?
  address     String?
  postalCode  String?
  city        String?
  country     String?
  siret       String?
  vatNumber   String?
  email       String?
  phone       String?
  website     String?
  createdAt   DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes      Quote[]
  invoices    Invoice[]
  @@index([userId])
}

model Quote {
  id               String       @id @default(cuid())
  userId           String
  number           String
  status           String       @default("draft") // draft | sent | signed | expired
  clientId         String?
  companyId        String?
  issueDate        String
  dueDate          String?
  currency         String       @default("EUR")
  paymentTerms     String?
  paymentMethod    String?
  totalHT          Float        @default(0)
  vatAmount        Float        @default(0)
  totalTTC         Float        @default(0)
  tvaNonApplicable Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client           Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  company          Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  lines            QuoteLine[]
  invoices         Invoice[]
  @@unique([userId, number])
  @@index([userId])
}

model QuoteLine {
  id       String  @id @default(cuid())
  quoteId  String
  type     String  @default("service")
  description String
  quantity Float   @default(1)
  unitPrice Float
  vatRate  Float   @default(20)
  discount Float   @default(0)
  total    Float
  quote    Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Invoice {
  id               String         @id @default(cuid())
  userId           String
  number           String
  status           String         @default("draft") // draft | sent | paid | pending | late | cancelled
  clientId         String?
  companyId        String?
  quoteId          String?
  issueDate        String
  dueDate          String?
  currency         String         @default("EUR")
  paymentTerms     String?
  paymentMethod    String?
  totalHT          Float          @default(0)
  vatAmount        Float          @default(0)
  totalTTC         Float          @default(0)
  tvaNonApplicable Boolean        @default(false)
  paidAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client           Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  company          Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  quote            Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  lines            InvoiceLine[]
  @@unique([userId, number])
  @@index([userId])
}

model InvoiceLine {
  id        String   @id @default(cuid())
  invoiceId String
  type      String   @default("service")
  description String
  quantity  Float    @default(1)
  unitPrice Float
  vatRate   Float    @default(20)
  discount  Float    @default(0)
  total     Float
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Expense {
  id           String   @id @default(cuid())
  userId       String
  date         String
  amount       Float
  category     String
  description  String?
  supplier     String?
  invoiceFile  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String   // invoice, quote, client, company, expense
  entityId   String?
  metadata   String?  // JSON
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model BillingSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  companyName        String?
  legalStatus        String?
  siret              String?
  vatNumber          String?
  address            String?
  phone              String?
  email              String?
  website            String?
  logoUrl            String?
  bankAccountHolder  String?
  bankName           String?
  bankIban           String?
  bankBic            String?
  nextInvoiceNumber  Int      @default(1)
  nextQuoteNumber    Int      @default(1)
  expenseCategories  String?  // JSON array
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BillingProduct {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String  @default("")
  type        String  @default("service")
  unitPrice   Float
  vatRate     Float    @default(20)
  discount    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}
