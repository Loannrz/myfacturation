// MyFacturation360 — Multi-tenant SaaS facturation
// NextAuth + billing (userId sur toutes les entités)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ——— NextAuth (tables standards) ———
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires   DateTime
  @@id([identifier, token])
}

// ——— User (profil + abonnement futur) ———
model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?   // pour login email/password
  verificationCode     String?   // code à 6 chiffres (vérification email)
  verificationCodeExp  DateTime? // expiration du code
  resetPasswordCode    String?   // code pour réinitialisation mot de passe
  resetPasswordCodeExp DateTime? // expiration du code reset
  phone                String?   // téléphone (profil)
  newEmailPending      String?   // nouvel email en attente de vérification
  newEmailCode         String?   // code envoyé au nouvel email
  newEmailCodeExp      DateTime? // expiration du code
  planType             String    @default("free")   // free | premium (dérivé de subscription_plan)
  subscriptionPlan     String    @default("starter") // starter | pro | business
  billingCycle         String?   // monthly | yearly
  subscriptionStatus   String?   // null | active | cancelled | past_due (Stripe)
  subscriptionStart   DateTime?
  subscriptionEnd     DateTime?
  stripeCustomerId    String?   // Stripe customer id (cus_xxx)
  stripeSubscriptionId String?  // Stripe subscription id (sub_xxx)
  hasUsedTrial         Boolean  @default(false)   // true si l'utilisateur a déjà utilisé un essai gratuit (un seul par compte)
  role                String    @default("user")   // user | admin
  suspended           Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  accounts            Account[]
  sessions            Session[]
  clients              Client[]
  companies            Company[]
  employees            Employee[]
  quotes               Quote[]
  invoices             Invoice[]
  creditNotes          CreditNote[]
  expenses             Expense[]
  activityLogs         ActivityLog[]
  billingSettings      BillingSettings?
  billingProducts      BillingProduct[]
  conversations        Conversation[]
}

// ——— Support / messagerie interne ———
model Conversation {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject            String    @db.Text
  status             String    @default("open")   // open | resolved
  adminLastOpenedAt   DateTime? // dernière ouverture par l'admin (pour afficher "Ouvert le ...")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  messages           Message[]
  @@index([userId])
  @@index([status])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  senderRole     String       // user | admin
  message        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime    @default(now())
  @@index([conversationId])
  @@index([isRead])
}

// ——— Admin: plans et permissions ———
model Plan {
  id          String   @id @default(cuid())
  key         String   @unique  // starter | pro | business
  name        String
  priceMonthly Int     @default(0)
  priceYearly Int     @default(0)
  description String? @db.Text
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  features    PlanFeature[]
}

model PlanFeature {
  id       String  @id @default(cuid())
  planKey  String  // starter | pro | business
  feature  String  // factures | devis | produits | clients | avoirs | ...
  enabled  Boolean @default(true)
  limit_   Int?    // null = illimité (pour factures/devis)
  plan     Plan    @relation(fields: [planKey], references: [key], onDelete: Cascade)
  @@unique([planKey, feature])
  @@map("plan_features")
}

// ——— Facturation (multi-tenant: userId partout) ———

model Client {
  id              String    @id @default(cuid())
  userId          String
  type            String    // "particulier" | "professionnel" | "association" | "entreprise"
  firstName       String
  lastName        String
  email           String
  phone           String?
  address         String?
  postalCode      String?
  city            String?
  country         String?
  language        String?   @default("fr")
  notes           String?
  companyName     String?
  companyAddress  String?
  siret           String?
  vatNumber       String?
  legalForm       String?
  createdAt       DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes         Quote[]
  invoices       Invoice[]
  creditNotes    CreditNote[]
  expenses       Expense[]
  @@index([userId])
  @@index([userId, deletedAt])
}

model Company {
  id          String    @id @default(cuid())
  userId      String
  type        String    @default("societe") // societe | association
  name        String
  legalName   String?
  address     String?
  postalCode  String?
  city        String?
  country     String?
  siret       String?
  vatNumber   String?
  vatExempt   Boolean   @default(false) // true = non assujetti à la TVA (masque n° TVA, mention légale sur documents)
  email       String?
  phone       String?
  website     String?
  createdAt   DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes      Quote[]
  invoices    Invoice[]
  creditNotes CreditNote[]
  expenses    Expense[]
  @@index([userId])
  @@index([userId, deletedAt])
}

model Quote {
  id               String       @id @default(cuid())
  userId           String
  number           String
  status           String       @default("draft") // draft | sent | signed | expired
  clientId         String?
  companyId        String?
  issueDate        String
  dueDate          String?
  currency         String       @default("EUR")
  paymentTerms     String?
  paymentMethod    String?
  bankAccountId    String?
  emitterProfileId String?
  totalHT          Float        @default(0)
  vatAmount        Float        @default(0)
  totalTTC         Float        @default(0)
  tvaNonApplicable Boolean      @default(false)
  signedAt         DateTime?
  sentAt           DateTime?
  signToken        String?      @unique
  signatureImageBase64 String?
  signerName       String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client           Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  company          Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  lines            QuoteLine[]
  invoices         Invoice[]
  @@unique([userId, number])
  @@index([userId])
  @@index([userId, deletedAt])
}

model QuoteLine {
  id       String  @id @default(cuid())
  quoteId  String
  type     String  @default("service")
  description String
  quantity Float   @default(1)
  unitPrice Float
  vatRate  Float   @default(20)
  discount Float   @default(0)
  total    Float
  quote    Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Invoice {
  id               String         @id @default(cuid())
  userId           String
  number           String
  status           String         @default("draft") // draft | sent | paid | pending | late | cancelled
  clientId         String?
  companyId        String?
  quoteId          String?
  issueDate        String
  dueDate          String?
  currency         String         @default("EUR")
  paymentTerms     String?
  paymentMethod    String?
  bankAccountId    String?
  emitterProfileId String?
  totalHT          Float          @default(0)
  vatAmount        Float          @default(0)
  totalTTC         Float          @default(0)
  tvaNonApplicable Boolean        @default(false)
  note             String?        // note / mention sur la facture (optionnel, pour Factur-X)
  paidAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client           Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  company          Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  quote            Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  lines            InvoiceLine[]
  creditNotes      CreditNote[]
  @@unique([userId, number])
  @@index([userId])
  @@index([userId, deletedAt])
}

model InvoiceLine {
  id        String   @id @default(cuid())
  invoiceId String
  type      String   @default("service")
  description String
  quantity  Float    @default(1)
  unitPrice Float
  vatRate   Float    @default(20)
  discount  Float    @default(0)
  total     Float
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model CreditNote {
  id               String           @id @default(cuid())
  userId           String
  number           String
  status           String           @default("draft") // draft | sent | refunded | cancelled
  invoiceId        String?          // facture d'origine
  clientId        String?
  companyId       String?
  issueDate       String
  currency        String           @default("EUR")
  totalHT         Float            @default(0)
  vatAmount       Float            @default(0)
  totalTTC        Float            @default(0)
  tvaNonApplicable Boolean         @default(false)
  reason           String?         // motif avoir (obligatoire pour Factur-X / EN16931)
  dueDate          String?         // date d'échéance paiement
  paymentTerms     String?         // conditions de paiement
  refundedAt       DateTime?      // date du remboursement quand status = refunded
  emitterProfileId String?
  bankAccountId   String?
  paymentMethod   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  client          Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  lines           CreditNoteLine[]
  @@unique([userId, number])
  @@index([userId])
  @@index([userId, deletedAt])
  @@index([invoiceId])
}

model CreditNoteLine {
  id          String     @id @default(cuid())
  creditNoteId String
  type        String     @default("service")
  description String
  quantity    Float      @default(1)
  unitPrice   Float
  vatRate     Float      @default(20)
  discount    Float      @default(0)
  total       Float
  creditNote  CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
}

// ——— Salariés (plan Business uniquement) ———
model Employee {
  id                   String    @id @default(cuid())
  userId               String
  firstName            String
  lastName             String
  email                String
  phone                String?
  address              String?
  city                 String?
  postalCode           String?
  country              String?
  position             String?   // poste dans l'entreprise
  contractType         String?   // CDD | CDI | Alternant | Autre
  hireDate             String?   // YYYY-MM-DD
  status               String    @default("active") // active | inactive
  socialSecurityNumber String?   // numéro de sécurité sociale (optionnel)
  internalNotes        String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses             Expense[]
  @@index([userId])
  @@index([userId, status])
  @@index([userId, deletedAt])
}

model Expense {
  id             String    @id @default(cuid())
  userId         String
  companyId      String?   // société liée (optionnel)
  clientId       String?   // particulier / client (optionnel)
  employeeId     String?   // salarié concerné (si catégorie = Salaires)
  bankAccountId  String?   // id du compte (BillingSettings.bankAccounts JSON)
  date           String
  amount         Float
  category       String
  description    String?
  supplier       String?
  invoiceFile    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  client         Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  employee       Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([userId, deletedAt])
  @@index([companyId])
  @@index([clientId])
  @@index([employeeId])
  @@index([bankAccountId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String   // invoice, quote, client, company, expense
  entityId   String?
  metadata   String?  // JSON
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

// Événements système (webhook Stripe, etc.) pour le dashboard admin
model SystemEvent {
  id         String   @id @default(cuid())
  eventType  String   // user_signup, subscription_started, subscription_canceled, payment_success, payment_failed
  userId     String?
  metadata   String?  @db.Text // JSON
  createdAt  DateTime @default(now())
  @@index([eventType])
  @@index([createdAt])
}

// Messages affichés sur le dashboard utilisateur (gérés par l'admin, 0 à 10 actifs)
model DashboardMessage {
  id        String   @id @default(cuid())
  icon      String   // nom Lucide : FileCheck, Shield, etc.
  title     String   @db.Text
  body      String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Log des emails envoyés (transactionnels, etc.) pour le dashboard admin
model EmailLog {
  id          String   @id @default(cuid())
  emailType   String   // welcome, trial_start, payment_success, etc.
  recipient   String
  subject     String   @db.Text
  bodyPreview String?  @db.Text
  bodyFull    String?  @db.Text
  userId      String?
  createdAt   DateTime @default(now())
  @@index([createdAt])
}

// Emails de comptes supprimés par l'admin : empêche de réinscrire avec le même email
model DeletedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  deletedAt DateTime @default(now())
  @@index([email])
}

model BillingSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  companyName           String?
  legalStatus           String?
  siret                 String?
  vatNumber             String?
  apeCode               String?  // code APE / NAF
  address               String?
  postalCode            String?
  city                  String?
  country               String?
  phone                 String?
  email                 String?
  website               String?
  logoUrl               String?
  bankAccountHolder     String?
  bankName              String?
  bankIban              String?
  bankBic               String?
  bankAccounts          String?  // JSON array of { id, name, accountHolder, bankName, iban, bic }
  emitterProfiles       String?  // JSON array (id, companyName, legalStatus, siret, vatNumber?, apeCode?, address, postalCode, city, country?, phone?, email?, website?)
  nextInvoiceNumber     Int      @default(1)
  nextQuoteNumber       Int      @default(1)
  nextCreditNoteNumber  Int      @default(1)
  invoiceNumberMiddle   String?
  invoiceNumberFormat   String?  // sequential | ddmm_seq | year_seq
  invoicePrefix         String?  // préfixe facture (ex: F)
  quoteNumberMiddle     String?
  quoteNumberFormat     String?
  quotePrefix           String?  // préfixe devis (ex: D)
  creditNumberMiddle    String?
  creditNumberFormat    String?
  creditNotePrefix      String?  // préfixe avoir (ex: A)
  defaultPaymentMethod  String?  // mode de paiement par défaut
  defaultPaymentTerms   String?  // conditions de paiement (ex: 30 jours)
  legalPenaltiesText    String?  // texte pénalités de retard
  legalRecoveryFeeText  String?  // texte indemnité forfaitaire recouvrement
  expenseCategories     String?
  vatApplicable         Boolean  @default(true)  // true = assujetti TVA, false = non assujetti (TVA 0, total HT = TTC)
  vatExemptionReason    String?  // motif exonération (ex: article 293 B CGI), affiché sur PDF si non assujetti
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BillingProduct {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String  @default("")
  type        String  @default("service")
  unitPrice   Float
  vatRate     Float    @default(20)
  discount    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}
