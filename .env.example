# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/myfacturation"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-secret"

# Google OAuth (optionnel)
GOOGLE_CLIENT_ID=""
