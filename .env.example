# Database (en prod Vercel : mettre l’URL Postgres dans DATABASE_URL ou l’un de :)
# MYFACTURATION_PRISMA_DATABASE_URL, MYFACTURATION_POSTGRES_URL, MYFACTURATION_DATABASE_URL,
# POSTGRES_URL, URL_DE_LA_BASE_DE_DONNEES_MYFACTURATION_PRISMA, URL_POSTGRES_DE_MON_FACTURATION
DATABASE_URL="postgresql://user:password@localhost:5432/myfacturation360"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# SMTP (Hostinger – transactional emails)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@myfacturation360.fr
SMTP_PASSWORD=YOUR_EMAIL_PASSWORD
# Optional: custom "From" address (defaults to SMTP_USER)
# SMTP_FROM=noreply@myfacturation360.fr

# App URL (used in verification and reset links in emails)
NEXT_PUBLIC_APP_URL=https://myfacturation360.fr

# Stripe (paiement formules) – utiliser des Price ID (price_...), pas des Product ID (prod_...)
# Tableau de bord Stripe : Produits → [votre produit] → Tarifs → copier l’ID du prix
# En prod : définir aussi NEXTAUTH_URL ou NEXT_PUBLIC_APP_URL (ex. https://myfacturation360.fr) pour la redirection après paiement
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_... (Développeurs → Webhooks → ajouter l’endpoint /api/stripe/webhook)
# PRICE_PRO_MONTHLY=price_...
# PRICE_PRO_YEARLY=price_...
# PRICE_BUSINESS_MONTHLY=price_...
# PRICE_BUSINESS_YEARLY=price_...

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: skip email verification for new signups (e.g. when SMTP not ready)
# SKIP_EMAIL_VERIFICATION=false

# Emails transactionnels (bienvenue, essai, paiement, annulation, hebdo)
# SUPPORT_EMAIL=support@myfacturation360.fr
# NEXT_PUBLIC_APP_NAME=Myfacturation360

# Cron (rappels fin d'essai + email hebdo) – protéger les routes /api/cron/*
# CRON_SECRET=your-secret-here
