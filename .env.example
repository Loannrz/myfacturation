# SMTP (emails: vérification, factures/devis)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@myfacturation.com"

# App (optionnel)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Token téléchargement PDF (optionnel, sinon NEXTAUTH_SECRET)
BILLING_DOWNLOAD_SECRET=""
